{
  "auth": {
    "signup": {
      "method": "POST",
      "url": "/api/auth/signup",
      "body": {
        "name": "Admin User",
        "email": "admin@example.com",
        "password": "StrongPass123!",
        "role": "admin"
      }
    },
    "login": {
      "method": "POST",
      "url": "/api/auth/login",
      "body": {
        "email": "admin@example.com",
        "password": "StrongPass123!"
      }
    },
    "refreshToken": {
      "method": "POST",
      "url": "/api/auth/refresh-token",
      "body": {
        "refreshToken": "paste_refresh_token_here"
      }
    },
    "logout": {
      "method": "POST",
      "url": "/api/auth/logout",
      "body": {
        "refreshToken": "paste_refresh_token_here"
      }
    }
  },
  "categories": {
    "create": {
      "method": "POST",
      "url": "/api/categories",
      "headers": {
        "Authorization": "Bearer <access_token>"
      },
      "body": {
        "name": "Electronics"
      }
    },
    "update": {
      "method": "PUT",
      "url": "/api/categories/:id",
      "headers": {
        "Authorization": "Bearer <access_token>"
      },
      "body": {
        "name": "Mobile Devices"
      }
    }
  },
  "products": {
    "create": {
      "method": "POST",
      "url": "/api/products",
      "headers": {
        "Authorization": "Bearer <access_token>"
      },
      "body": {
        "name": "iPhone 16",
        "description": "Latest smartphone",
        "price": 1299.99,
        "categoryIds": [
          "11111111-1111-4111-8111-111111111111",
          "22222222-2222-4222-8222-222222222222"
        ]
      }
    },
    "update": {
      "method": "PUT",
      "url": "/api/products/:id",
      "headers": {
        "Authorization": "Bearer <access_token>"
      },
      "body": {
        "name": "iPhone 16 Pro",
        "price": 1499.99,
        "categoryIds": [
          "11111111-1111-4111-8111-111111111111"
        ]
      }
    }
  }
}
